// --- NEW SCREEN: PLAYER ROSTER & TEAM ASSIGNMENT ---
void drawRosterScreen() {
  tft.fillScreen(C_BG);
  drawHeader("ROSTER (TAP TO SWAP)");
  drawButton(240, 35, 70, 30, C_GREY, "Back");
  drawButton(240, 70, 70, 30, C_RED, "Wipe");

  int startX = 10;
  int startY = 40;
  int boxW = 65;
  int boxH = 40;
  int padding = 10;
  
  int count = 0;
  
  // Draw up to 12 player boxes on screen
  for(int i = 0; i < MAX_PLAYERS; i++) {
    if(players[i].active) {
      if (count >= 12) break; // Out of physical screen space
      
      int row = count / 3;
      int col = count % 3;
      int bx = startX + (col * (boxW + padding));
      int by = startY + (row * (boxH + padding));
      
      uint16_t tCol = C_WHITE;
      if (players[i].team == 1) tCol = C_RED;
      else if (players[i].team == 2) tCol = C_BLUE;
      else if (players[i].team == 3) tCol = C_GREEN;
      else if (players[i].team == 4) tCol = C_YELLOW;

      tft.fillRoundRect(bx, by, boxW, boxH, 4, tft.color565(30, 30, 40));
      tft.drawRoundRect(bx, by, boxW, boxH, 4, tCol);
      
      tft.setTextColor(C_WHITE);
      tft.setTextSize(1);
      tft.setCursor(bx + 5, by + 5);
      tft.print("GUN "); tft.print(players[i].id);
      
      tft.setTextColor(tCol);
      tft.setTextSize(2);
      tft.setCursor(bx + 25, by + 20);
      if(players[i].team == 1) tft.print("R");
      else if(players[i].team == 2) tft.print("B");
      else if(players[i].team == 3) tft.print("G");
      else if(players[i].team == 4) tft.print("Y");

      count++;
    }
  }
  
  if (count == 0) {
    tft.setTextColor(C_GREY);
    tft.setTextSize(2);
    tft.setCursor(30, 120);
    tft.print("No Operators Online");
  }
}

// =========================================================================
// SMART NETWORK ROUTINE
// =========================================================================

void connectToNetwork() {
  tft.fillScreen(C_BG);
  tft.setTextColor(C_WHITE);
  tft.setTextSize(2);
  tft.setCursor(10, 100); tft.print("SEARCHING FOR");
  tft.setCursor(10, 130); tft.print("ARENA ROUTER...");

  WiFi.mode(WIFI_STA);
  IPAddress local_IP(192, 168, 1, 100);
  IPAddress gateway(192, 168, 1, 1);
  IPAddress subnet(255, 255, 255, 0);
  WiFi.config(local_IP, gateway, subnet);
  WiFi.begin(routerSSID, routerPass);

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) { 
    delay(500);
    attempts++;
  }

  tft.fillScreen(C_BG);
  if (WiFi.status() == WL_CONNECTED) {
    usingExternalRouter = true;
    tft.setTextColor(C_GREEN);
    tft.setCursor(10, 100); tft.print("ROUTER FOUND!");
    tft.setCursor(10, 130); tft.print("IP: 192.168.1.100");
    dnsServer.start(DNS_PORT, customDomain, WiFi.localIP());
  } else {
    usingExternalRouter = false;
    tft.setTextColor(C_YELLOW);
    tft.setCursor(10, 100); tft.print("ROUTER NOT FOUND");
    tft.setCursor(10, 130); tft.print("STARTING CYD HUB");
    WiFi.disconnect();
    WiFi.mode(WIFI_AP);
    WiFi.softAP(apSSID, apPass);
    dnsServer.start(DNS_PORT, customDomain, WiFi.softAPIP());
  }
  delay(2000); 
}

// =========================================================================
// MAIN SETUP
// =========================================================================

void setup() {
  Serial.begin(115200);

  // Turn on TFT Backlight
  pinMode(TFT_BL, OUTPUT);
  digitalWrite(TFT_BL, HIGH);

  // Init Touch (VSPI)
  SPI.begin(XPT2046_CLK, XPT2046_MISO, XPT2046_MOSI, XPT2046_CS);
  ts.begin();
  ts.setRotation(1); 

  // Init TFT (HSPI)
  tftSpi.begin(TFT_CLK, TFT_MISO, TFT_MOSI, TFT_CS);
  tft.begin();
  tft.setRotation(1); 
  
  for(int i = 0; i < MAX_PLAYERS; i++) players[i].active = false;
  
  connectToNetwork();
  
  server.on("/", handleRoot);
  server.on("/join", handleJoin);
  server.on("/status", handleStatus);
  server.on("/set", handleSet);
  server.on("/setrules", handleSetRules);
  server.on("/hit", handleHit);
  server.on("/clearscores", handleClearScores);
  
  server.onNotFound([]() {
    server.sendHeader("Location", "/", true);
    server.send(302, "text/plain", "");
  });

  server.begin();
  drawMainScreen();
}

// =========================================================================
// TOUCH HANDLING & MAIN LOOP
// =========================================================================

bool checkTouchArea(int tx, int ty, int bx, int by, int bw, int bh) {
  return (tx >= bx && tx <= bx + bw && ty >= by && ty <= by + bh);
}

void processTouch(int tx, int ty) {
  if (currentScreen == 0) { // MAIN
    if (checkTouchArea(tx, ty, 10, 115, 140, 50)) { hostStatus = 1; gameStartTime = millis(); drawMainScreen(); } 
    else if (checkTouchArea(tx, ty, 10, 175, 140, 50)) { hostStatus = 2; drawMainScreen(); } 
    else if (checkTouchArea(tx, ty, 170, 115, 140, 50)) { currentScreen = 1; drawSetupScreen1(); }
    else if (checkTouchArea(tx, ty, 170, 175, 140, 50)) { currentScreen = 3; drawRosterScreen(); }
  } 
  else if (currentScreen == 1) { // SETUP 1
    if (checkTouchArea(tx, ty, 240, 35, 70, 30)) { currentScreen = 0; drawMainScreen(); return; } 
    if (checkTouchArea(tx, ty, 240, 70, 70, 30)) { currentScreen = 2; drawSetupScreen2(); return; } 
    
    bool updated = false;
    if (checkTouchArea(tx, ty, 10, 55, 100, 30)) { gameMode = 1; updated = true; }
    if (checkTouchArea(tx, ty, 120, 55, 90, 30)) { gameMode = 0; updated = true; }

    if (checkTouchArea(tx, ty, 10, 115, 50, 35)) { configLives = 1; updated = true; }
    if (checkTouchArea(tx, ty, 70, 115, 50, 35)) { configLives = 3; updated = true; }
    if (checkTouchArea(tx, ty, 130, 115, 50, 35)) { configLives = 5; updated = true; }
    if (checkTouchArea(tx, ty, 190, 115, 50, 35)) { configLives = 10; updated = true; }

    if (checkTouchArea(tx, ty, 10, 185, 50, 35)) { configMags = 2; updated = true; }
    if (checkTouchArea(tx, ty, 70, 185, 50, 35)) { configMags = 5; updated = true; }
    if (checkTouchArea(tx, ty, 130, 185, 50, 35)) { configMags = 10; updated = true; }
    if (checkTouchArea(tx, ty, 190, 185, 50, 35)) { configMags = 30; updated = true; }
    if (updated) drawSetupScreen1(); 
  }
  else if (currentScreen == 2) { // SETUP 2
    if (checkTouchArea(tx, ty, 240, 35, 70, 30)) { currentScreen = 1; drawSetupScreen1(); return; } 

    bool updated = false;
    if (checkTouchArea(tx, ty, 10, 60, 50, 40)) { baseDamage = 10; updated = true; }
    if (checkTouchArea(tx, ty, 70, 60, 50, 40)) { baseDamage = 25; updated = true; }
    if (checkTouchArea(tx, ty, 130, 60, 50, 40)) { baseDamage = 50; updated = true; }
    if (checkTouchArea(tx, ty, 190, 60, 50, 40)) { baseDamage = 100; updated = true; }

    if (checkTouchArea(tx, ty, 10, 140, 50, 40)) { configHealth = 50; updated = true; }
    if (checkTouchArea(tx, ty, 70, 140, 50, 40)) { configHealth = 100; updated = true; }
    if (checkTouchArea(tx, ty, 130, 140, 50, 40)) { configHealth = 150; updated = true; }
    if (checkTouchArea(tx, ty, 190, 140, 50, 40)) { configHealth = 200; updated = true; }
    if (updated) drawSetupScreen2();
  }
  else if (currentScreen == 3) { // ROSTER
    if (checkTouchArea(tx, ty, 240, 35, 70, 30)) { currentScreen = 0; drawMainScreen(); return; } 
    if (checkTouchArea(tx, ty, 240, 70, 70, 30)) { handleClearScores(); return; } 

    // Check taps on player boxes to change teams
    int count = 0;
    for(int i = 0; i < MAX_PLAYERS; i++) {
      if(players[i].active) {
        if (count >= 12) break; 
        int row = count / 3;
        int col = count % 3;
        int bx = 10 + (col * (65 + 10));
        int by = 40 + (row * (40 + 10));
        
        if (checkTouchArea(tx, ty, bx, by, 65, 40)) {
          players[i].team++;
          if (players[i].team > 4) players[i].team = 1;
          drawRosterScreen();
          return;
        }
        count++;
      }
    }
  }
}

void loop() {
  dnsServer.processNextRequest(); 
  server.handleClient(); 

  // Read Touch Panel
  if (ts.tirqTouched() && ts.touched()) {
    TS_Point p = ts.getPoint();
    // Standard XPT2046 mapping for Rotation 1
    int mapX = map(p.x, 300, 3800, 0, 320);
    int mapY = map(p.y, 300, 3800, 0, 240);
    processTouch(mapX, mapY);
    delay(250); // Debounce
  }

  // Update Main Menu Live Timer
  if (currentScreen == 0 && hostStatus == 1) {
    if (millis() - lastTimerUpdate >= 1000) {
      lastTimerUpdate = millis();
      unsigned long el = (millis() - gameStartTime) / 1000;
      char buf[10]; sprintf(buf, "%d:%02d", (int)(el/60), (int)(el%60));
      tft.fillRoundRect(65, 45, 190, 50, 5, tft.color565(30, 30, 40));
      tft.setTextColor(C_BLUE);
      tft.setTextSize(5);
      tft.setCursor(95, 50);
      tft.print(buf);
    }
  }
}
