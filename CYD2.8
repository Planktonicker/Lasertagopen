void drawButton(int x, int y, int w, int h, uint16_t color, const char* text, bool isSelected = false) {
  if (isSelected) {
    tft.fillRoundRect(x, y, w, h, 4, C_WHITE);
    tft.drawRoundRect(x, y, w, h, 4, C_BLUE);
    tft.setTextColor(C_BLACK);
  } else {
    tft.fillRoundRect(x, y, w, h, 4, color);
    tft.setTextColor(color == C_YELLOW || color == C_GREEN ? C_BLACK : C_WHITE);
  }
  
  tft.setTextSize(2);
  int textWidth = strlen(text) * 12; // Approximation for size 2 font
  int textHeight = 16;               
  tft.setCursor(x + (w - textWidth) / 2, y + (h - textHeight) / 2);
  tft.print(text);
}

void drawHeader(const char* title) {
  tft.fillRect(0, 0, 320, 30, tft.color565(20, 20, 30));
  tft.drawLine(0, 30, 320, 30, C_BLUE);
  tft.setTextColor(C_BLUE);
  tft.setTextSize(2);
  tft.setCursor(10, 8);
  tft.print(title);
  
  // Network Indicator
  tft.setCursor(260, 8);
  tft.setTextColor(usingExternalRouter ? C_GREEN : C_YELLOW);
  tft.print(usingExternalRouter ? "[LA]" : "[LAH]");
}

void drawMainScreen() {
  tft.fillScreen(C_BG);
  drawHeader("ARENA COMMAND");
  
  // Timer Box
  tft.fillRoundRect(60, 40, 200, 60, 5, tft.color565(30, 30, 40));
  tft.drawRoundRect(60, 40, 200, 60, 5, C_BLUE);
  tft.setTextColor(C_BLUE);
  tft.setTextSize(5);
  
  if (hostStatus == 1 && gameStartTime > 0) {
    unsigned long el = (millis() - gameStartTime) / 1000;
    char buf[10]; sprintf(buf, "%d:%02d", (int)(el/60), (int)(el%60));
    tft.setCursor(95, 50); tft.print(buf);
  } else {
    tft.setCursor(95, 50); tft.print("0:00");
  }

  // Left Column - Game Control
  drawButton(10, 115, 140, 50, C_GREEN, "START GAME", hostStatus == 1);
  drawButton(10, 175, 140, 50, C_RED, "KILL ALL", hostStatus == 2); 
  
  // Right Column - Setup & Teams
  drawButton(170, 115, 140, 50, C_YELLOW, "RULES...");
  drawButton(170, 175, 140, 50, C_BLUE, "ROSTER..."); 
}

