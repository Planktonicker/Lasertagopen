int configLives  = 3;
int configMags   = 5;
int configHealth = 100;
int gameMode     = 0;  // 0=Combat, 1=Unlimited

#define MAX_PLAYERS 64

struct PlayerRecord {
  int id;
  int team; // 1=Red, 2=Blue, 3=Green, 4=Yellow
  int kills;
  int deaths;
  bool active;
};

PlayerRecord players[MAX_PLAYERS]; 
int playerCount = 0;

// =========================================================================
// UI & DISPLAY STATE
